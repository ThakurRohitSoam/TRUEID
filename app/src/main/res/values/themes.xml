<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.TRUEID" parent="android:Theme.Material.Light.NoActionBar" />
    <style name="Theme.Launch" parent="Theme.SplashScreen">
        <!-- Set the splash screen background, animated icon, and animation
        duration. -->
        <item name="windowSplashScreenBackground">@color/logo_background</item>

        <!-- Use windowSplashScreenAnimatedIcon to add a drawable or an animated
             drawable. One of these is required. -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/tick_fill_logo</item>
        <!-- Required for animated icons. -->
        <item name="windowSplashScreenAnimationDuration">1000</item>

        <!-- Set the theme of the Activity that directly follows your splash
        screen. This is required. -->
        <item name="postSplashScreenTheme">@style/Theme.TRUEID</item>
    </style>
</resources>